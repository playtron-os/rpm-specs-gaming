+++ b/src/freedreno/common/freedreno_dev_info.h
@@ -147,6 +147,13 @@ struct fd_dev_info {
 
       bool has_8bpp_ubwc;
 
+      /* a7xx_gen3+ / a8xx have a bug where tiled R8 (cpp=1) textures
+       * produce corruption (horizontal line artifacts at tile boundaries)
+       * when partial sub-region updates are performed via buffer-to-image
+       * copies. Force linear layout for cpp=1 images as a workaround.
+       */
+      bool r8_tiling_quirk;
+
       bool has_lpac;
 
       bool has_getfiberid;
