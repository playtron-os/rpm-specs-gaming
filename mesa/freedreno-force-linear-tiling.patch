diff --git a/src/freedreno/vulkan/tu_image.cc b/src/freedreno/vulkan/tu_image.cc
index d7dcf81367e..f886c495b83 100644
--- a/src/freedreno/vulkan/tu_image.cc
+++ b/src/freedreno/vulkan/tu_image.cc
@@ -699,6 +699,18 @@ tu_image_init(struct tu_device *device, struct tu_image *image,
       image->force_linear_tile = true;
    }
 
+   /* a7xx_gen3+ / a8xx have a bug with tiled R8 (1 byte-per-pixel) textures
+    * where partial sub-region updates via buffer-to-image copies produce
+    * corruption (horizontal line artifacts at tile boundaries). Force linear
+    * layout for these formats as a workaround.
+    */
+   if (device->physical_device->info->props.r8_tiling_quirk &&
+       vk_format_get_blocksize(image->vk.format) == 1 &&
+       !util_format_is_depth_or_stencil(
+          vk_format_to_pipe_format(image->vk.format))) {
+      image->force_linear_tile = true;
+   }
+
    if (image->force_linear_tile ||
        !ubwc_possible(device, image->vk.format, pCreateInfo->imageType,
                       pCreateInfo->flags, pCreateInfo->usage,
